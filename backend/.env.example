# Example MongoDB connection string (replace with your own)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.example.mongodb.net/otd?retryWrites=true&w=majority

# JWT secret for signing tokens (must be kept secret in production)
JWT_SECRET=your_jwt_secret_here

# HTTP port
PORT=5000

# Rate limiter settings
RATE_LIMIT_MAX=100

# Redis cache URL (optional). If omitted, an in-memory cache is used.
#REDIS_URL=redis://localhost:6379

# License lookup cache TTL in milliseconds
LICENSE_CACHE_TTL_MS=60000
